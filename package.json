{
  "name": "astro-carve",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Astro integration for the Carve markup language - use .crv/.carve files as pages and imports, rendered to HTML via carve-js",
  "license": "MIT",
  "author": "Mark Scherer",
  "keywords": [
    "astro",
    "astro-integration",
    "astro-component",
    "carve",
    "markup",
    "withastro"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@markup-carve/carve": "git+https://github.com/markup-carve/carve-js.git"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "astro": "^7.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "astro": ">=4.0.0 <8.0.0"
  }
}
